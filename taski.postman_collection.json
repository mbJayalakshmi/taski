{
  "info": {
    "name": "taski API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "eventId", "value": "" },
    { "key": "seatId1", "value": "" },
    { "key": "seatId2", "value": "" },
    { "key": "bookingId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Joy Dev\",\n  \"email\": \"joy@example.com\",\n  \"password\": \"password123\"\n}" }
          }
        },
        {
          "name": "Login (User)",
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.collectionVariables.set('token', pm.response.json().token);"] }
          }],
          "request": {
            "method": "POST",
            "url": "{{base}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"joy@example.com\",\n  \"password\": \"password123\"\n}" }
          }
        },
        {
          "name": "Login (Admin)",
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.collectionVariables.set('adminToken', pm.response.json().token);"] }
          }],
          "request": {
            "method": "POST",
            "url": "{{base}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@taski.com\",\n  \"password\": \"admin123\"\n}" }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{base}}/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Wallet",
      "item": [
        {
          "name": "Get Balance",
          "request": {
            "method": "GET",
            "url": "{{base}}/wallet",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Add Money (₹500)",
          "request": {
            "method": "POST",
            "url": "{{base}}/wallet/add",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"amount\": 50000\n}" }
          }
        },
        {
          "name": "Transaction History",
          "request": {
            "method": "GET",
            "url": "{{base}}/wallet/transactions?page=1&limit=10",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "List Events",
          "request": { "method": "GET", "url": "{{base}}/events" }
        },
        {
          "name": "Get Event",
          "request": { "method": "GET", "url": "{{base}}/events/{{eventId}}" }
        },
        {
          "name": "Get Seats",
          "request": {
            "method": "GET",
            "url": "{{base}}/events/{{eventId}}/seats",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Reserve Seats",
          "request": {
            "method": "POST",
            "url": "{{base}}/bookings/reserve",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"eventId\": \"{{eventId}}\",\n  \"seatIds\": [\"{{seatId1}}\", \"{{seatId2}}\"]\n}" }
          }
        },
        {
          "name": "Confirm Booking",
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.collectionVariables.set('bookingId', pm.response.json().booking?._id);"] }
          }],
          "request": {
            "method": "POST",
            "url": "{{base}}/bookings/confirm",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"eventId\": \"{{eventId}}\",\n  \"seatIds\": [\"{{seatId1}}\", \"{{seatId2}}\"],\n  \"idempotencyKey\": \"unique-uuid-here\"\n}" }
          }
        },
        {
          "name": "My Bookings",
          "request": {
            "method": "GET",
            "url": "{{base}}/bookings",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Create Event",
          "request": {
            "method": "POST",
            "url": "{{base}}/admin/events",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Bangalore Tech Fest\",\n  \"description\": \"Annual tech conference\",\n  \"venue\": \"KTPO, Whitefield\",\n  \"date\": \"2026-05-15T10:00:00.000Z\",\n  \"totalSeats\": 100,\n  \"pricePerSeat\": 49900\n}" }
          }
        },
        {
          "name": "Bulk Create Seats",
          "request": {
            "method": "POST",
            "url": "{{base}}/admin/events/{{eventId}}/seats/bulk",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"rows\": [\"A\", \"B\", \"C\", \"D\", \"E\"],\n  \"seatsPerRow\": 20\n}" }
          }
        },
        {
          "name": "All Bookings",
          "request": {
            "method": "GET",
            "url": "{{base}}/admin/bookings?page=1&limit=15",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        },
        {
          "name": "Filter Bookings by Status",
          "request": {
            "method": "GET",
            "url": "{{base}}/admin/bookings?status=confirmed",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        },
        {
          "name": "Cancel Booking & Refund",
          "request": {
            "method": "POST",
            "url": "{{base}}/admin/bookings/{{bookingId}}/cancel",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"reason\": \"Event rescheduled\"\n}" }
          }
        },
        {
          "name": "All Transactions",
          "request": {
            "method": "GET",
            "url": "{{base}}/admin/transactions?page=1",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        },
        {
          "name": "All Users",
          "request": {
            "method": "GET",
            "url": "{{base}}/admin/users",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        },
        {
          "name": "View Seat States",
          "request": {
            "method": "GET",
            "url": "{{base}}/admin/events/{{eventId}}/seats",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        }
      ]
    }
  ]
}
