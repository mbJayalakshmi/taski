PORT=5000

# JWT secret — change this to any long random string
JWT_SECRET=change_this_to_any_long_random_string
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS) — set to your Vercel URL in production
CLIENT_URL=http://localhost:3000

# NOTE: No database needed. All data is stored in memory.
# Data resets when the server restarts — fine for demo/assessment.
